---
import "../styles/global.css";
import { client } from "../client.config.js";
const { title, description } = Astro.props;
const fullTitle = `${title} | ${client.name}`;
const metaDesc = description || client.tagline;
const currentPath = Astro.url.pathname;
const primary = client.primaryColor || "#2d5a3d";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style
      set:html={`
    :root {
      --primary: ${primary};
      --primary-rgb: ${(primary.replace("#", "").match(/.{2}/g) || ["00", "00", "00"]).map((x) => parseInt(x, 16)).join(",")};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #111; background: #fff; }
    h1, h2, h3, h4, .font-heading { font-family: 'Outfit', sans-serif; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }
    
    .header-container {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.5rem 0;
    }
    
    .nav-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      color: #fff;
    }

    .header-left, .header-right {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex: 1;
    }
    
    .header-right { justify-content: flex-end; }
    
    .header-center {
      display: flex;
      justify-content: center;
      flex: 0 0 auto;
    }

    .info-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .social-links {
      display: flex;
      gap: 1.25rem;
      align-items: center;
    }

    .social-links svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
      transition: opacity 0.2s;
    }
    
    .social-links a:hover svg { opacity: 0.7; }

    .lang-switcher {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      padding-left: 1.5rem;
      border-left: 1px solid rgba(255,255,255,0.3);
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.75rem;
      font-weight: 800;
      color: #fff;
    }

    .btn-primary { background: ${primary}; color: #fff; padding: 0.85rem 2rem; border-radius: 50px; font-weight: 700; font-size: 0.95rem; display: inline-block; border: none; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; text-transform: uppercase; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(var(--primary-rgb), 0.3); }
    
    .btn-outline { border: 2px solid #fff; color: #fff; padding: 0.85rem 2rem; border-radius: 50px; font-weight: 700; font-size: 0.95rem; display: inline-block; background: transparent; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn-outline:hover { background: #fff; color: ${primary}; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    
    #mobile-nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(0,0,0,0.95);
      z-index: 200;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }
    
    .mobile-link { font-size: 1.5rem; color: #fff; font-weight: 600; }

    @media (max-width: 1024px) {
      .header-left > .info-item, .header-right > .social-links { display: none; }
      .nav-wrapper { padding: 0 1.5rem; }
    }
  `}
    ></style>
  </head>
  <body style="min-height:100vh; display:flex; flex-direction:column">
    <header class="header-container">
      <div class="nav-wrapper">
        <div class="header-left">
          <a href={`tel:${client.phone}`} class="info-item desktop-only">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"
              ></path></svg
            >
            {client.phone}
          </a>
          <button id="menu-btn" class="menu-toggle">
            <svg
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2.5"><path d="M4 6h16M4 12h16M4 18h16"></path></svg
            >
            Menu
          </button>
        </div>

        <div class="header-center">
          <a href="/" class="logo">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.28 2 8 0 3.87-3.13 7-7 7h-3"
              ></path><path d="M7 20h4"></path><path
                d="M10 20c0-1.71-3.94-3.13-3.94-3.13C4.7 16.67 3 15.13 3 13.31c0-1.84 1.66-3.31 3.31-3.31V20Z"
              ></path></svg
            >
            <span
              >{client.name.split(" ")[0]}<span
                style="opacity:0.8;font-weight:400"
                >{client.name.split(" ").slice(1).join(" ")}</span
              ></span
            >
          </a>
        </div>

        <div class="header-right">
          <div class="social-links desktop-only">
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"
                ></path></svg
              ></a
            >
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
                ></path></svg
              ></a
            >
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path></svg
              ></a
            >
          </div>
          <div class="lang-switcher">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12.87 15.07L10.33 12.56L10.36 12.53C12.1 10.59 13.34 8.36 14.07 6H17V4H10V2H8V4H1V6H12.17C11.5 7.92 10.44 9.75 9 11.35C8.07 10.32 7.3 9.19 6.69 8H4.69C5.42 9.63 6.42 11.17 7.67 12.56L2.58 17.58L4 19L9 14L12.11 17.11L12.87 15.07M18.5 10H16.5L12 22H14L15.12 19H19.87L21 22H23L18.5 10M15.88 17L17.5 12.67L19.12 17H15.88Z"
              ></path></svg
            >
            Eng
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"
              ></path></svg
            >
          </div>
        </div>
      </div>
    </header>

    <div id="mobile-nav">
      <button
        id="close-menu"
        style="position:absolute;top:2rem;right:2rem;background:none;border:none;color:#fff;cursor:pointer"
      >
        <svg
          width="32"
          height="32"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"><path d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
      <a href="/" class="mobile-link">Home</a>
      <a href="/services" class="mobile-link">Services</a>
      <a href="/about" class="mobile-link">About</a>
      <a href="/gallery" class="mobile-link">Gallery</a>
      <a href="/testimonials" class="mobile-link">Reviews</a>
      <a href="/blog" class="mobile-link">Blog</a>
      <a href="/contact" class="mobile-link">Contact</a>
      <a href="/contact" class="btn-primary">Get Free Quote</a>
    </div>

    <main style="flex:1"><slot /></main>

    <footer style="background:#0f172a;color:#94a3b8;margin-top:0">
      <div class="container" style="padding:5rem 1.5rem">
        <div
          style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:3rem;margin-bottom:4rem"
        >
          <div>
            <a href="/" class="logo" style="margin-bottom:1.5rem">
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.28 2 8 0 3.87-3.13 7-7 7h-3"
                ></path><path d="M7 20h4"></path><path
                  d="M10 20c0-1.71-3.94-3.13-3.94-3.13C4.7 16.67 3 15.13 3 13.31c0-1.84 1.66-3.31 3.31-3.31V20Z"
                ></path></svg
              >
              <span style="color:#fff">{client.name}</span>
            </a>
            <p style="line-height:1.7;margin-bottom:1.5rem">{client.tagline}</p>
            <div class="social-links" style="color:#fff">
              <a href="#"
                ><svg viewBox="0 0 24 24" width="20"
                  ><path
                    d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"
                  ></path></svg
                ></a
              >
              <a href="#"
                ><svg viewBox="0 0 24 24" width="20"
                  ><path
                    d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
                  ></path></svg
                ></a
              >
            </div>
          </div>
          <div>
            <h4 style="color:#fff;font-size:1.1rem;margin-bottom:1.5rem">
              Quick Links
            </h4>
            <ul style="list-style:none;display:grid;gap:0.75rem">
              <li><a href="/" style="transition:color 0.2s">Home</a></li>
              <li>
                <a href="/services" style="transition:color 0.2s"
                  >Our Services</a>
              </li>
              <li>
                <a href="/about" style="transition:color 0.2s">About Us</a>
              </li>
              <li>
                <a href="/gallery" style="transition:color 0.2s"
                  >Project Gallery</a>
              </li>
              <li>
                <a href="/contact" style="transition:color 0.2s">Contact Us</a>
              </li>
            </ul>
          </div>
          <div>
            <h4 style="color:#fff;font-size:1.1rem;margin-bottom:1.5rem">
              Contact Info
            </h4>
            <ul style="list-style:none;display:grid;gap:1rem">
              <li style="display:flex;gap:0.75rem">
                <svg
                  width="20"
                  height="20"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    d="M12,11.5A2.5,2.5 0 0,1 9.5,9A2.5,2.5 0 0,1 12,6.5A2.5,2.5 0 0,1 14.5,9A2.5,2.5 0 0,1 12,11.5M12,2A7,7 0 0,0 5,9C5,14.25 12,22 12,22C12,22 19,14.25 19,9A7,7 0 0,0 12,2Z"
                  ></path></svg
                >
                {client.address}, {client.city}, {client.state}
              </li>
              <li style="display:flex;gap:0.75rem">
                <svg
                  width="20"
                  height="20"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    d="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"
                  ></path></svg
                >
                {client.phone}
              </li>
              <li style="display:flex;gap:0.75rem">
                <svg
                  width="20"
                  height="20"
                  fill="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    d="M20,8L12,13L4,8V6L12,11L20,6M20,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6C22,4.89 21.11,4 20,4Z"
                  ></path></svg
                >
                {client.email}
              </li>
            </ul>
          </div>
        </div>
        <div
          style="border-top:1px solid rgba(255,255,255,0.1);padding-top:2rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:1rem;font-size:0.85rem"
        >
          <p>
            © {new Date().getFullYear()}
            {client.name}. All rights reserved.
          </p>
          <div style="display:flex;gap:1.5rem">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const menuBtn = document.getElementById("menu-btn");
      const closeBtn = document.getElementById("close-menu");
      const mobileNav = document.getElementById("mobile-nav");

      menuBtn?.addEventListener("click", () => {
        if (mobileNav) mobileNav.style.display = "flex";
      });

      closeBtn?.addEventListener("click", () => {
        if (mobileNav) mobileNav.style.display = "none";
      });
    </script>
  </body>
</html>
