---
import "../styles/global.css";
import { client } from "../client.config.js";
const { title, description } = Astro.props;
const fullTitle = `${title} | ${client.name}`;
const metaDesc = description || client.tagline;
const currentPath = Astro.url.pathname;
const primary = client.primaryColor || "#b45309";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={metaDesc} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"
      is:inline></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"
      is:inline></script>
    <script src="https://unpkg.com/lenis@1.1.13/dist/lenis.min.js" is:inline></script>
    <style
      set:html={`
    :root {
      --primary: ${primary};
      --primary-rgb: ${(primary.replace("#", "").match(/.{2}/g) || ["00", "00", "00"]).map((x) => parseInt(x, 16)).join(",")};
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: #111; background: #fff; }
    h1, h2, h3, h4, .font-heading { font-family: 'Outfit', sans-serif; }
    a { text-decoration: none; color: inherit; }
    img { max-width: 100%; height: auto; }
    
    .header-container {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
      padding: 1.5rem 0;
    }
    
    .nav-wrapper {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      color: #fff;
    }

    .header-left, .header-right {
      display: flex;
      align-items: center;
      gap: 2rem;
      flex: 1;
    }
    
    .header-right { justify-content: flex-end; }
    
    .header-center {
      display: flex;
      justify-content: center;
      flex: 0 0 auto;
    }

    .info-item {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .social-links {
      display: flex;
      gap: 1.25rem;
      align-items: center;
    }

    .social-links svg {
      width: 18px;
      height: 18px;
      fill: currentColor;
      transition: opacity 0.2s;
    }
    
    .social-links a:hover svg { opacity: 0.7; }

    .lang-switcher {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 0.85rem;
      font-weight: 600;
      text-transform: uppercase;
      padding-left: 1.5rem;
      border-left: 1px solid rgba(255,255,255,0.3);
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      background: none;
      border: none;
      color: #fff;
      cursor: pointer;
      font-size: 0.9rem;
      font-weight: 700;
      text-transform: uppercase;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 1.75rem;
      font-weight: 800;
      color: #fff;
    }

    .btn-primary { background: ${primary}; color: #fff; padding: 0.85rem 2rem; border-radius: 50px; font-weight: 700; font-size: 0.95rem; display: inline-block; border: none; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; text-transform: uppercase; }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 20px rgba(var(--primary-rgb), 0.3); }
    
    .btn-outline { border: 2px solid #fff; color: #fff; padding: 0.85rem 2rem; border-radius: 50px; font-weight: 700; font-size: 0.95rem; display: inline-block; background: transparent; cursor: pointer; transition: all 0.2s; text-transform: uppercase; }
    .btn-outline:hover { background: #fff; color: ${primary}; }

    .container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
    
    #mobile-nav {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100vh;
      background: rgba(0,0,0,0.95);
      z-index: 200;
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      padding-top: 6rem;
      padding-bottom: 3rem;
      gap: 2rem;
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    .mobile-link { font-size: 1.5rem; color: #fff; font-weight: 600; }

    @media (max-width: 1024px) {
      .header-left > .info-item, .header-right > .social-links { display: none; }
      .nav-wrapper { padding: 0 1.5rem; }
      .header-container { padding: 1rem 0; }
    }
    
    @media (max-width: 768px) {
      .header-center .logo span { font-size: 1.1rem; }
      .header-center .logo svg { width: 22px; height: 22px; }
      .header-center .logo { gap: 0.4rem; }
      .menu-toggle { font-size: 0.8rem; gap: 0.3rem; }
      .menu-toggle svg { width: 22px; height: 22px; }
      .lang-switcher { display: none; }
      .header-left, .header-right { gap: 0.5rem; flex: 1; }
      .nav-wrapper { padding: 0 1rem; }
    }

    /* Custom Cursor Styles */
    .cursor-dot, .cursor-ring {
      position: fixed;
      top: 0;
      left: 0;
      border-radius: 50%;
      pointer-events: none;
      z-index: 99999;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .cursor-dot {
      width: 8px;
      height: 8px;
      background: var(--primary);
    }

    .cursor-ring {
      width: 40px;
      height: 40px;
      border: 1.5px solid var(--primary);
      display: flex;
      align-items: center;
      justify-content: center;
      transition: width 0.3s cubic-bezier(0.23, 1, 0.32, 1), 
                  height 0.3s cubic-bezier(0.23, 1, 0.32, 1), 
                  background 0.3s ease, 
                  border-color 0.3s ease;
    }

    .cursor-text {
      font-size: 12px;
      font-weight: 700;
      color: #fff;
      opacity: 0;
      transform: scale(0.5);
      transition: all 0.3s cubic-bezier(0.23, 1, 0.32, 1);
      text-transform: uppercase;
      letter-spacing: 1px;
      font-family: 'Outfit', sans-serif;
    }

    body:hover .cursor-dot, body:hover .cursor-ring {
      opacity: 1;
    }

    .cursor-active .cursor-ring {
      transform: scale(1.5);
      background: rgba(var(--primary-rgb), 0.1);
      border-color: transparent;
    }

    .cursor-view .cursor-ring {
      width: 100px;
      height: 100px;
      background: #000;
      border-color: transparent;
    }

    .cursor-view .cursor-text {
      opacity: 1;
      transform: scale(1);
    }

    .cursor-text-hover .cursor-ring {
      width: 80px;
      height: 80px;
      background: #fff;
      mix-blend-mode: difference;
      border-color: transparent;
    }

    .cursor-text-hover .cursor-dot, .cursor-view .cursor-dot {
      opacity: 0 !important;
    }

    @media (max-width: 1024px) {
      .cursor-dot, .cursor-ring { display: none !important; }
    }

    /* Footer Styles */
    footer {
      background: #0d4429;
      color: #d1ccc5;
      position: relative;
    }

    footer::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: url('https://www.transparenttextures.com/patterns/leaves.png');
      opacity: 0.05;
      pointer-events: none;
      z-index: 1;
    }

    .grass-decoration {
      position: absolute;
      bottom: 100%;
      left: 0;
      width: 100%;
      height: 140px;
      display: block;
      z-index: 20;
      pointer-events: none;
      margin-bottom: -2px; /* Slight overlap to prevent gaps */
    }

    footer .logo { color: #fff; }
    footer .logo span { color: #fff; font-size: 1.2rem; }

    footer a { color: #d1ccc5; transition: color 0.2s; }
    footer a:hover { color: #b45309; }

    footer h4 { 
      color: #fff; 
      font-size: 1rem; 
      margin-bottom: 1.5rem; 
      font-weight: 600;
      letter-spacing: 0.3px;
    }
    
    footer ul { list-style: none; gap: 0.75rem; }
    footer ul li { font-size: 0.95rem; }

    footer .social-links a:hover { 
      background: #b45309 !important;
      transform: translateY(-3px);
    }

    @media (max-width: 768px) {
      .grass-decoration {
        height: 60px;
      }
      
      footer .container {
        padding: 2rem 1.5rem !important;
      }
      
      footer > div {
        grid-template-columns: 1fr !important;
      }
      
      .newsletter-col {
        grid-column: span 1 !important;
      }
      
      .footer-bottom {
        flex-direction: column;
        text-align: center;
        gap: 1.5rem !important;
      }
      .footer-bottom div {
        justify-content: center;
      }
    }
  `}
    ></style>
  </head>
  <body style="min-height:100vh; display:flex; flex-direction:column">
    <div class="cursor-dot"></div>
    <div class="cursor-ring">
      <span class="cursor-text">View</span>
    </div>
    <header class="header-container">
      <div class="nav-wrapper">
        <div class="header-left">
          <a href={`tel:${client.phone}`} class="info-item desktop-only">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M6.62,10.79C8.06,13.62 10.38,15.94 13.21,17.38L15.41,15.18C15.69,14.9 16.08,14.82 16.43,14.93C17.55,15.3 18.75,15.5 20,15.5A1,1 0 0,1 21,16.5V20A1,1 0 0,1 20,21A17,17 0 0,1 3,4A1,1 0 0,1 4,3H7.5A1,1 0 0,1 8.5,4C8.5,5.25 8.7,6.45 9.07,7.57C9.18,7.92 9.1,8.31 8.82,8.59L6.62,10.79Z"
              ></path></svg
            >
            {client.phone}
          </a>
          <button id="menu-btn" class="menu-toggle">
            <svg
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              stroke-width="2.5"><path d="M4 6h16M4 12h16M4 18h16"></path></svg
            >
            Menu
          </button>
        </div>

        <div class="header-center">
          <a href="/" class="logo">
            <svg
              width="32"
              height="32"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.28 2 8 0 3.87-3.13 7-7 7h-3"
              ></path><path d="M7 20h4"></path><path
                d="M10 20c0-1.71-3.94-3.13-3.94-3.13C4.7 16.67 3 15.13 3 13.31c0-1.84 1.66-3.31 3.31-3.31V20Z"
              ></path></svg
            >
            <span
              >{client.name.split(" ")[0]}<span
                style="opacity:0.8;font-weight:400"
                >{client.name.split(" ").slice(1).join(" ")}</span
              ></span
            >
          </a>
        </div>

        <div class="header-right">
          <div class="social-links desktop-only">
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M22.675 0h-21.35c-.732 0-1.325.593-1.325 1.325v21.351c0 .731.593 1.324 1.325 1.324h11.495v-9.294h-3.128v-3.622h3.128v-2.671c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12v9.293h6.116c.73 0 1.323-.593 1.323-1.325v-21.35c0-.732-.593-1.325-1.325-1.325z"
                ></path></svg
              ></a
            >
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417a9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"
                ></path></svg
              ></a
            >
            <a href="#"
              ><svg viewBox="0 0 24 24"
                ><path
                  d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                ></path></svg
              ></a
            >
          </div>
          <div class="lang-switcher">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M12.87 15.07L10.33 12.56L10.36 12.53C12.1 10.59 13.34 8.36 14.07 6H17V4H10V2H8V4H1V6H12.17C11.5 7.92 10.44 9.75 9 11.35C8.07 10.32 7.3 9.19 6.69 8H4.69C5.42 9.63 6.42 11.17 7.67 12.56L2.58 17.58L4 19L9 14L12.11 17.11L12.87 15.07M18.5 10H16.5L12 22H14L15.12 19H19.87L21 22H23L18.5 10M15.88 17L17.5 12.67L19.12 17H15.88Z"
              ></path></svg
            >
            Eng
            <svg width="12" height="12" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"
              ></path></svg
            >
          </div>
        </div>
      </div>
    </header>

    <div id="mobile-nav">
      <button
        id="close-menu"
        style="position:fixed;top:2rem;right:2rem;background:none;border:none;color:#fff;cursor:pointer;z-index:201;"
      >
        <svg
          width="32"
          height="32"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          stroke-width="2"><path d="M6 18L18 6M6 6l12 12"></path></svg
        >
      </button>
      <a href="/" class="mobile-link">Home</a>
      <a href="/services" class="mobile-link">Services</a>
      <a href="/about" class="mobile-link">About</a>
      <a href="/gallery" class="mobile-link">Gallery</a>
      <a href="/testimonials" class="mobile-link">Reviews</a>
      <a href="/blog" class="mobile-link">Blog</a>
      <a href="/contact" class="mobile-link">Contact</a>
      <a href="/contact" class="btn-primary">Get Free Quote</a>
    </div>

    <main style="flex:1"><slot /></main>

    <footer
      style={`background: linear-gradient(to bottom, #f8f1ec 0%, #ede3db 100%); color: #1a1a1a; padding: 6rem 1.5rem 2rem; position: relative; overflow: hidden;`}
    >
      <div
        class="container"
        style="max-width: 1400px; position: relative; z-index: 2;"
      >
        <div
          style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 4rem; margin-bottom: 4rem;"
        >
          <!-- Location 1 -->
          <div>
            <h3
              style={`color: ${primary}; font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem;`}
            >
              {client.name}
            </h3>
            <p style="opacity: 0.8; line-height: 1.8; margin-bottom: 1rem;">
              USA — {client.address},<br />
              {client.city}, {client.state}
            </p>
            <p style="margin-bottom: 0.5rem;">
              <a
                href={`mailto:${client.email}`}
                style="text-decoration: none; color: inherit; border-bottom: 1px solid rgba(0,0,0,0.1);"
                >{client.email}</a
              >
            </p>
            <p>
              <a
                href={`tel:${client.phone}`}
                style="text-decoration: none; color: inherit;">{client.phone}</a
              >
            </p>
          </div>

          <!-- Location 2 (Support) -->
          <div>
            <h3
              style={`color: ${primary}; font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem;`}
            >
              Support
            </h3>
            <p style="opacity: 0.8; line-height: 1.8; margin-bottom: 1rem;">
              Our dedicated support team is available <br />
              to help you with any landscaping needs.
            </p>
            <p style="margin-bottom: 0.5rem;">
              <a
                href="/contact"
                style="text-decoration: none; color: inherit; border-bottom: 1px solid rgba(0,0,0,0.1);"
                >Contact Support</a
              >
            </p>
            <p>{client.phone}</p>
          </div>

          <!-- Newsletter -->
          <div class="newsletter-col" style="grid-column: span 2;">
            <h3
              style="font-size: 1.5rem; font-weight: 800; margin-bottom: 1.5rem;"
            >
              Subscribe to our latest insights
            </h3>
            <p style="opacity: 0.7; line-height: 1.6; margin-bottom: 2rem;">
              Subscribe to our Newsletter Event right now to be updated on
              special offers Gardening and Landscaping.
            </p>
            <div style="position: relative; max-width: 500px;">
              <input
                type="email"
                placeholder="Email Address"
                style="width: 100%; background: #fff; border: 1px solid rgba(0,0,0,0.1); padding: 1.25rem 4rem 1.25rem 1.5rem; border-radius: 50px; color: #1a1a1a; outline: none;"
              />
              <button
                style={`position: absolute; right: 8px; top: 8px; bottom: 8px; width: 44px; background: ${primary}; border: none; border-radius: 50%; color: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px ${primary}33;`}
              >
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"
                  ></path></svg
                >
              </button>
            </div>
          </div>
        </div>

        <div
          class="footer-bottom"
          style="border-top: 1px solid rgba(0,0,0,0.05); padding-top: 2rem; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; font-size: 0.9rem; opacity: 0.6;"
        >
          <p>
            © Copyright {new Date().getFullYear()}. All rights reserved. {
              client.name
            }
          </p>
          <div style="display: flex; gap: 2rem;">
            <a href="/privacy" style="color: inherit; text-decoration: none;"
              >Privacy Policy</a
            >
            <a href="/terms" style="color: inherit; text-decoration: none;"
              >Terms & Services</a
            >
          </div>
        </div>
      </div>
    </footer>

    <script is:inline>
      // Initialize Lenis
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        orientation: 'vertical',
        gestureOrientation: 'vertical',
        smoothWheel: true,
        wheelMultiplier: 1,
        smoothTouch: false,
        touchMultiplier: 2,
        infinite: false,
      })

      // Link Lenis to GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update)

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000)
      })

      gsap.ticker.lagSmoothing(0)

      const menuBtn = document.getElementById("menu-btn");
      const closeBtn = document.getElementById("close-menu");
      const mobileNav = document.getElementById("mobile-nav");

      menuBtn?.addEventListener("click", () => {
        if (mobileNav) mobileNav.style.display = "flex";
      });

      closeBtn?.addEventListener("click", () => {
        if (mobileNav) mobileNav.style.display = "none";
      });

      // GSAP Custom Cursor
      const dot = document.querySelector(".cursor-dot");
      const ring = document.querySelector(".cursor-ring");
      const interactiveElements =
        "a, button, .service-card, .btn-primary, .btn-outline";

      if (dot && ring && window.innerWidth > 1024) {
        gsap.set(dot, { xPercent: -50, yPercent: -50 });
        gsap.set(ring, { xPercent: -50, yPercent: -50 });

        const xToDot = gsap.quickTo(dot, "x", { duration: 0.1, ease: "none" });
        const yToDot = gsap.quickTo(dot, "y", { duration: 0.1, ease: "none" });

        const xToRing = gsap.quickTo(ring, "x", {
          duration: 0.4,
          ease: "power3",
        });
        const yToRing = gsap.quickTo(ring, "y", {
          duration: 0.4,
          ease: "power3",
        });

        window.addEventListener("mousemove", (e) => {
          xToDot(e.clientX);
          yToDot(e.clientY);
          xToRing(e.clientX);
          yToRing(e.clientY);
        });

        document.querySelectorAll(interactiveElements).forEach((el) => {
          el.addEventListener("mouseenter", () => {
            document.body.classList.add("cursor-active");
            gsap.to(ring, { scale: 1.5, duration: 0.3 });
            gsap.to(dot, { scale: 0, duration: 0.3 });
          });
          el.addEventListener("mouseleave", () => {
            document.body.classList.remove("cursor-active");
            gsap.to(ring, { scale: 1, duration: 0.3 });
            gsap.to(dot, { scale: 1, duration: 0.3 });
          });
        });

        // "View" Cursor for images and service cards
        const viewElements = "img, .hero-image-wrapper, .service-card";
        document.querySelectorAll(viewElements).forEach((el) => {
          el.addEventListener("mouseenter", () => {
            document.body.classList.add("cursor-view");
            gsap.to(ring, { scale: 1, duration: 0.3 });
          });
          el.addEventListener("mouseleave", () => {
            document.body.classList.remove("cursor-view");
          });
        });

        // "Inverted" Cursor for text
        const textElements = "h1, h2, h3, h4, h5, h6, .font-heading";
        document.querySelectorAll(textElements).forEach((el) => {
          el.addEventListener("mouseenter", () => {
            document.body.classList.add("cursor-text-hover");
            gsap.to(ring, { scale: 1, duration: 0.3 });
          });
          el.addEventListener("mouseleave", () => {
            document.body.classList.remove("cursor-text-hover");
          });
        });
      }
    </script>
  </body>
</html>
