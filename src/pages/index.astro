---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";

let services = [];
let testimonials = [];
try {
  const [s, t] = await Promise.all([
    fetch(
      `${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=6`,
    ),
    fetch(
      `${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=3`,
    ),
  ]);
  services = (await s.json()).docs || [];
  testimonials = (await t.json()).docs || [];
} catch {}

const displayServices = services.length
  ? services
  : client.services.map((s: string) => ({
      title: s,
      description: `Professional ${s.toLowerCase()} services in ${client.city}.`,
    }));

const primary = client.primaryColor || "#2d5a3d";
---

<Layout title="Home" description={client.tagline}>
  <section
    style={`position:relative; padding:10rem 1.5rem 12rem; background:${primary}; overflow:hidden;`}
  >
    <!-- Slanted Bottom Overlay -->
    <div
      style="position:absolute; bottom:0; left:0; width:100%; height:150px; background:#fff; clip-path: polygon(0 100%, 100% 100%, 100% 0); pointer-events:none;"
    >
    </div>
    <!-- Decorative Overlays -->
    <div
      class="decorative-waves"
      style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0.1; pointer-events:none;"
    >
      <svg
        width="100%"
        height="100%"
        viewBox="0 0 800 800"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
        stroke="#fff"
        stroke-width="1"
      >
        <path d="M100,700 Q300,600 200,400 T400,100" opacity="0.5"></path>
        <circle cx="750" cy="50" r="100" stroke-dasharray="5 5"></circle>
        <circle cx="750" cy="50" r="120" stroke-dasharray="5 5"></circle>
        <circle cx="750" cy="50" r="140" stroke-dasharray="5 5"></circle>
      </svg>
    </div>

    <!-- Large Leaf Outline -->
    <div
      class="decorative-leaf"
      style="position:absolute; bottom:-50px; left:-100px; opacity:0.15; transform: rotate(-15deg); pointer-events:none;"
    >
      <svg
        width="600"
        height="600"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#fff"
        stroke-width="0.5"
        ><path
          d="M12 20s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 6.2c0 7.3-8 11.8-8 11.8z"
        ></path><path d="M12 22v-2"></path><path d="M12 8l-4 4"></path><path
          d="M12 11l4 4"></path><path d="M12 5l-2 2"></path><path d="M12 14l2 2"
        ></path></svg
      >
    </div>

    <div
      class="container"
      style="position:relative; z-index:10; display:grid; grid-template-columns: 1fr 1fr; gap:4rem; align-items:center;"
    >
      <div class="hero-content">
        <div style="margin-bottom:1.5rem">
          <span
            style="background:rgba(255,255,255,0.15); color:#fff; padding:0.5rem 1.25rem; border-radius:50px; font-size:0.9rem; font-weight:700; text-transform:uppercase; letter-spacing:1px; border:1px solid rgba(255,255,255,0.2)"
          >
            Welcome to {client.name}
          </span>
        </div>
        <h1
          style="font-size:clamp(2.5rem, 6vw, 4.5rem); font-weight:800; color:#fff; line-height:1; margin-bottom:2rem; text-transform:capitalize;"
        >
          {client.services[0]}
          <br />
          <span style="opacity:0.9; font-weight:400;">{client.services[1]}</span
          >
          <br />
          {client.services[2]}
        </h1>
        <p
          style="font-size:1.15rem; color:rgba(255,255,255,0.8); line-height:1.7; margin-bottom:2.5rem; max-width:500px;"
        >
          {client.tagline}. We provide professional landscaping solutions
          tailored to your needs in {client.city} and surrounding areas.
        </p>
        <div style="display:flex; gap:1.25rem; flex-wrap:wrap">
          <a
            href="/services"
            class="btn-primary"
            style="background:#84cc16; color:#fff;">Explore Garden</a
          >
          <a href="/about" class="btn-outline">Learn More</a>
        </div>
      </div>

      <div style="position:relative;">
        <!-- Wave Pattern -->
        <div
          class="decorative-waves"
          style="position:absolute; top:-40px; right:-40px; z-index:0; opacity:0.3;"
        >
          <svg width="200" height="200" viewBox="0 0 200 200">
            <circle
              cx="100"
              cy="100"
              r="40"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="55"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="70"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="85"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
          </svg>
        </div>

        <div
          class="hero-image-wrapper"
          style="position:relative; z-index:5; border-radius: 40px 40px 200px 40px; overflow:hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);"
        >
          <img
            src="/images/hero-gardener.png"
            alt="Gardening Professional"
            style="width:100%; height:600px; object-fit:cover;"
          />
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes float {
      0%,
      100% {
        transform: translate3d(0, 0, 0);
      }
      50% {
        transform: translate3d(0, -20px, 0);
      }
    }

    @keyframes float-slow {
      0%,
      100% {
        transform: translate3d(0, 0, 0) rotate(0deg);
      }
      50% {
        transform: translate3d(0, -15px, 0) rotate(2deg);
      }
    }

    @keyframes rotate-pulse {
      0% {
        transform: rotate(0deg) scale(1);
        opacity: 0.3;
      }
      50% {
        transform: rotate(180deg) scale(1.05);
        opacity: 0.5;
      }
      100% {
        transform: rotate(360deg) scale(1);
        opacity: 0.3;
      }
    }

    .hero-image-wrapper {
      animation: float 6s ease-in-out infinite;
      will-change: transform;
    }

    .decorative-leaf {
      animation: float-slow 8s ease-in-out infinite;
      will-change: transform;
    }

    .decorative-waves {
      animation: rotate-pulse 12s linear infinite;
      will-change: transform, opacity;
    }

    @media (max-width: 968px) {
      .container {
        grid-template-columns: 1fr !important;
        gap: 3rem !important;
        padding-top: 4rem !important;
      }
      .hero-image-wrapper {
        order: -1;
        animation-duration: 4s;
      }
      h1 {
        font-size: 3rem !important;
      }
    }
  </style>

  <div class="marquee-wrapper">
    <div class="marquee-strip primary-strip">
      <div class="marquee-content">
        {
          [...Array(4)].map(() => (
            <>
              {[
                "✓ Licensed & Insured",
                "✓ Free Estimates",
                "✓ Same Day Service",
                "✓ 5-Star Rated",
                "✓ Satisfaction Guaranteed",
              ].map((b) => (
                <span class="marquee-item">{b}</span>
              ))}
            </>
          ))
        }
      </div>
    </div>
    <div class="marquee-strip light-strip">
      <div class="marquee-content reverse">
        {
          [...Array(4)].map(() => (
            <>
              {[
                "✓ Licensed & Insured",
                "✓ Free Estimates",
                "✓ Same Day Service",
                "✓ 5-Star Rated",
                "✓ Satisfaction Guaranteed",
              ].map((b) => (
                <span class="marquee-item">{b}</span>
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>

  <style>
    .marquee-wrapper {
      position: relative;
      background: #fff;
      padding: 4rem 0;
      overflow: hidden;
      margin-top: -3rem;
      z-index: 20;
    }

    .marquee-strip {
      display: flex;
      white-space: nowrap;
      padding: 1rem 0;
      width: 120%;
      margin-left: -10%;
    }

    .primary-strip {
      background: var(--primary);
      color: #fff;
      transform: rotate(-2deg);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      z-index: 2;
    }

    .light-strip {
      background: #f8fafc;
      color: #334155;
      transform: rotate(1deg);
      margin-top: -3.5rem;
      border-top: 1px solid #e2e8f0;
      border-bottom: 1px solid #e2e8f0;
      z-index: 1;
    }

    .marquee-content {
      display: flex;
      gap: 3rem;
      animation: marquee 30s linear infinite;
    }

    .marquee-content.reverse {
      animation: marquee-reverse 35s linear infinite;
    }

    .marquee-item {
      font-family: "Outfit", sans-serif;
      font-weight: 800;
      font-size: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 3rem;
    }

    .marquee-item::after {
      content: "|";
      opacity: 0.3;
    }

    @keyframes marquee {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    @keyframes marquee-reverse {
      0% {
        transform: translateX(-50%);
      }
      100% {
        transform: translateX(0);
      }
    }
  </style>

  <section
    style="padding: 8rem 1.5rem; background: #f0fdf4; position: relative; overflow: hidden;"
  >
    <!-- Grass/Leaf Patterns -->
    <div
      style="position: absolute; top: 0; left: 0; width: 100%; height: 80px; opacity: 0.08; pointer-events: none; background-image: url(&quot;data:image/svg+xml,%3Csvg width='120' height='60' viewBox='0 0 120 60' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 60C10 40 5 10 20 10C35 10 30 40 40 60C50 40 45 10 60 10C75 10 70 40 80 60C90 40 85 10 100 10C115 10 110 40 120 60' stroke='%232d5a3d' stroke-width='2'/%3E%3C/svg%3E&quot;); background-repeat: repeat-x;"
    >
    </div>
    <div
      style="position: absolute; bottom: 0; left: 0; width: 100%; height: 80px; opacity: 0.08; pointer-events: none; background-image: url(&quot;data:image/svg+xml,%3Csvg width='120' height='60' viewBox='0 0 120 60' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 60C10 40 5 10 20 10C35 10 30 40 40 60C50 40 45 10 60 10C75 10 70 40 80 60C90 40 85 10 100 10C115 10 110 40 120 60' stroke='%232d5a3d' stroke-width='2'/%3E%3C/svg%3E&quot;); background-repeat: repeat-x; transform: rotate(180deg);"
    >
    </div>

    <div class="container" style="position: relative; z-index: 1;">
      <!-- Header Section -->
      <div
        style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: flex-end; margin-bottom: 5rem;"
      >
        <div>
          <div
            style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;"
          >
            <div
              style={`width: 32px; height: 32px; border-radius: 8px; background: ${primary}15; display: flex; align-items: center; justify-content: center;`}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke={primary}
                stroke-width="2"
                ><path
                  d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.28 2 8 0 3.87-3.13 7-7 7h-3"
                ></path></svg
              >
            </div>
            <span
              style={`color: ${primary}; font-weight: 700; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px;`}
              >Services</span
            >
          </div>
          <h2
            style={`font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.1; color: ${primary}; font-weight: 800;`}
          >
            Comprehensive {client.industry} services for homeowners and businesses
            in
            {client.city}.
          </h2>
        </div>
        <div>
          <p
            style="font-size: 1.15rem; color: #4b5563; line-height: 1.7; margin-bottom: 2rem;"
          >
            Enhance your outdoor space with our professional garden landscaping
            services, customized to suit every need and preference. From design
            to installation, we create beautiful, functional gardens that
            reflect your style.
          </p>
          <div style="display: flex; gap: 0.5rem;">
            <div
              style={`width: 10px; height: 10px; border-radius: 50%; background: ${primary};`}
            >
            </div>
            <div
              style="width: 10px; height: 10px; border-radius: 50%; background: #d1d5db;"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Services Grid -->
      <div
        style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;"
      >
        {
          [
            { title: "Landscape Design", image: "/images/service-design.png" },
            {
              title: "Garden Installation",
              image: "/images/service-installation.png",
            },
            {
              title: "Lawn Care & Maintenance",
              image: "/images/service-maintenance.png",
            },
          ].map((s) => (
            <div
              class="service-card"
              style="position: relative; height: 400px; border-radius: 40px; overflow: hidden; cursor: pointer; transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); box-shadow: 0 20px 40px rgba(0,0,0,0.1);"
            >
              <img
                src={s.image}
                alt={s.title}
                style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s ease;"
              />
              <div style="position: absolute; inset: 0; background: linear-gradient(to bottom, rgba(0,0,0,0.4) 0%, transparent 40%, rgba(0,0,0,0.3) 100%);" />
              <div style="position: absolute; top: 2.5rem; left: 2.5rem;">
                <h3 style="color: #fff; font-size: 1.5rem; font-weight: 700; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">
                  {s.title}
                </h3>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <style>
    .service-card:hover {
      transform: translateY(-15px) scale(1.02);
    }
    .service-card:hover img {
      transform: scale(1.1);
    }
    @media (max-width: 968px) {
      .container > div:first-child {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
      .container > div:last-child {
        grid-template-columns: 1fr !important;
      }
      .service-card {
        height: 300px !important;
      }
    }
  </style>

  <section style={`padding:4rem 1.5rem;background:${primary}12`}>
    <div style="max-width:1200px;margin:0 auto">
      <h2
        style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:2.5rem"
      >
        Why Choose {client.name}?
      </h2>
      <div
        style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem"
      >
        {
          [
            {
              icon: "🏆",
              title: "Years of Experience",
              desc: "Trusted by hundreds of local homeowners.",
            },
            {
              icon: "⚡",
              title: "Fast Response",
              desc: "Same-day service. We show up when we say.",
            },
            {
              icon: "💯",
              title: "Quality Guaranteed",
              desc: "Satisfaction guarantee on every job.",
            },
            {
              icon: "💰",
              title: "Fair Pricing",
              desc: "Transparent quotes. No hidden fees.",
            },
          ].map((item) => (
            <div style="text-align:center;padding:1.75rem 1.25rem;background:#fff;border-radius:12px;box-shadow:0 2px 8px rgba(0,0,0,0.05)">
              <div style="font-size:2.5rem;margin-bottom:0.75rem">
                {item.icon}
              </div>
              <h3 style="font-weight:700;margin-bottom:0.5rem">{item.title}</h3>
              <p style="color:#6b7280;font-size:0.875rem;line-height:1.6">
                {item.desc}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {
    testimonials.length > 0 && (
      <section style="padding:4rem 1.5rem">
        <div style="max-width:1200px;margin:0 auto">
          <h2 style="font-size:2rem;font-weight:700;text-align:center;margin-bottom:2.5rem">
            What Our Clients Say
          </h2>
          <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem">
            {testimonials.map((t: any) => (
              <div style="padding:1.5rem;background:#f9fafb;border-radius:12px;border:1px solid #e5e7eb">
                <div style="color:#facc15;margin-bottom:0.75rem">★★★★★</div>
                <p style="color:#374151;font-style:italic;margin-bottom:1rem;line-height:1.7">
                  "{t.text || t.content}"
                </p>
                <p style="font-weight:700">{t.name || t.author}</p>
                {t.location && (
                  <p style="font-size:0.8rem;color:#6b7280">{t.location}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section
    style={`padding:4rem 1.5rem;background:${primary};color:#fff;text-align:center`}
  >
    <div style="max-width:700px;margin:0 auto">
      <h2 style="font-size:2rem;font-weight:700;margin-bottom:1rem">
        Ready to Get Started?
      </h2>
      <p style="opacity:0.9;margin-bottom:2rem;font-size:1.05rem">
        Contact us today for a free, no-obligation estimate.
      </p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a
          href="/contact"
          style="background:#fff;color:#111;padding:0.85rem 2.5rem;border-radius:10px;font-weight:700"
          >Get Free Quote</a
        >
        <a
          href={`tel:${client.phone}`}
          style="border:2px solid rgba(255,255,255,0.7);color:#fff;padding:0.85rem 2.5rem;border-radius:10px;font-weight:700"
          >{client.phone || "Call Us"}</a
        >
      </div>
    </div>
  </section>
</Layout>
