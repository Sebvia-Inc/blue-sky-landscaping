                <p style="font-weight:700">{t.name || t.author}</p>
                {t.location && (
                  <p style="font-size:0.8rem;color:#6b7280">{t.location}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </section>
    )
  }

  <section
    style={`padding: 8rem 1.5rem; background: #f8f1ec; color: #1a1a1a; position: relative;`}
  >
    <div class="cta-container container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 3rem;">
      <div style="flex: 1; min-width: 300px;">
        <h2 style="font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800; line-height: 1.1; margin: 0;">
          We Care Your <br />
          <span style={`color: ${primary}`}>Garden Landscaping</span>
        </h2>
      </div>
      <div style="display: flex; flex-direction: column; align-items: flex-end; gap: 1.5rem; min-width: 300px;">
        <div style="display: flex; align-items: center; gap: 1rem;">
          <div style={`width: 48px; height: 48px; border-radius: 50%; background: ${primary}15; display: flex; align-items: center; justify-content: center; color: ${primary}`}>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
          </div>
          <span style="font-size: 1.75rem; font-weight: 700; color: #1a1a1a;">{client.phone}</span>
        </div>
        <a href="/contact" style={`background: ${primary}; color: #fff; padding: 1.1rem 2.5rem; border-radius: 8px; font-weight: 800; text-decoration: none; transition: all 0.3s ease; display: inline-block; box-shadow: 0 10px 20px ${primary}33;`}>
          Ask Feel Free Question here?
        </a>
      </div>
    </div>
  </section>

  <style>
    @media (max-width: 768px) {
      .cta-container {
        flex-direction: column;
        text-align: center;
        gap: 2rem !important;
      }
      .cta-container > div {
        align-items: center !important;
      }
    }
  </style>
</Layout>
<script is:inline>
  // Register ScrollTrigger
  gsap.registerPlugin(ScrollTrigger);

  // Animate Sections
  gsap.from(".feature-item", {
    scrollTrigger: {
      trigger: ".why-choose-us",
      start: "top 85%",
    },
    y: 50,
    opacity: 0,
    duration: 1,
    stagger: 0.1,
    ease: "power3.out",
  });

  gsap.from(".service-card", {
    scrollTrigger: {
      trigger: ".services-grid",
      start: "top 80%",
    },
    scale: 0.95,
    opacity: 0,
    duration: 0.8,
    stagger: 0.1,
    ease: "power2.out",
  });

  gsap.from(".hero-content > *", {
    y: 30,
    opacity: 0,
    duration: 1,
    stagger: 0.15,
    ease: "power4.out",
  });

  // Refresh ScrollTrigger after a short delay to ensure Lenis and layout are ready
  window.addEventListener('load', () => {
    setTimeout(() => {
      ScrollTrigger.refresh();
    }, 100);
  });
</script>
