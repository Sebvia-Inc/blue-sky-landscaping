---
import Layout from "../layouts/Layout.astro";
import { client } from "../client.config.js";

let services = [];
let testimonials = [];
try {
  const [s, t] = await Promise.all([
    fetch(
      `${client.cmsUrl}/api/services?where[tenant.slug][equals]=${client.tenantSlug}&limit=50`,
    ),
    fetch(
      `${client.cmsUrl}/api/testimonials?where[tenant.slug][equals]=${client.tenantSlug}&limit=3`,
    ),
  ]);
  services = (await s.json()).docs || [];
  testimonials = (await t.json()).docs || [];
} catch {}

const localServices = client.services.map((s: string) => ({
  title: s,
  description: `Professional ${s.toLowerCase()} services in ${client.city}.`,
}));

// Combine CMS and Local services, avoiding duplicates by title
const displayServices = [...services];
localServices.forEach((ls) => {
  if (
    !displayServices.find(
      (ds) => ds.title.toLowerCase() === ls.title.toLowerCase(),
    )
  ) {
    displayServices.push(ls);
  }
});

const primary = client.primaryColor || "#2d5a3d";
---

<Layout title="Home" description={client.tagline}>
  <section
    style={`position:relative; padding:10rem 1.5rem 12rem; background:${primary}; overflow:hidden;`}
  >
    <!-- Slanted Bottom Overlay -->
    <div
      style="position:absolute; bottom:0; left:0; width:100%; height:150px; background:#fff; clip-path: polygon(0 100%, 100% 100%, 100% 0); pointer-events:none;"
    >
    </div>
    <!-- Decorative Overlays -->
    <div
      class="decorative-waves"
      style="position:absolute; top:0; left:0; width:100%; height:100%; opacity:0.1; pointer-events:none;"
    >
      <svg
        width="100%"
        height="100%"
        viewBox="0 0 800 800"
        preserveAspectRatio="xMidYMid slice"
        fill="none"
        stroke="#fff"
        stroke-width="1"
      >
        <path d="M100,700 Q300,600 200,400 T400,100" opacity="0.5"></path>
        <circle cx="750" cy="50" r="100" stroke-dasharray="5 5"></circle>
        <circle cx="750" cy="50" r="120" stroke-dasharray="5 5"></circle>
        <circle cx="750" cy="50" r="140" stroke-dasharray="5 5"></circle>
      </svg>
    </div>

    <!-- Large Leaf Outline -->
    <div
      class="decorative-leaf"
      style="position:absolute; bottom:-50px; left:-100px; opacity:0.15; transform: rotate(-15deg); pointer-events:none;"
    >
      <svg
        width="600"
        height="600"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#fff"
        stroke-width="0.5"
        ><path
          d="M12 20s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 6.2c0 7.3-8 11.8-8 11.8z"
        ></path><path d="M12 22v-2"></path><path d="M12 8l-4 4"></path><path
          d="M12 11l4 4"></path><path d="M12 5l-2 2"></path><path d="M12 14l2 2"
        ></path></svg
      >
    </div>

    <div
      class="container"
      style="position:relative; z-index:10; display:grid; grid-template-columns: 1fr 1fr; gap:4rem; align-items:center;"
    >
      <div class="hero-content">
        <div style="margin-bottom:1.5rem">
          <span
            style="display:inline-block; max-width:100%; background:rgba(255,255,255,0.15); color:#fff; padding:0.5rem 1.25rem; border-radius:50px; font-size:clamp(0.65rem, 3vw, 0.9rem); font-weight:700; text-transform:uppercase; letter-spacing:1px; border:1px solid rgba(255,255,255,0.2); line-height:1.4;"
          >
            Welcome to {client.name}
          </span>
        </div>
        <h1
          style="font-size:clamp(2.5rem, 6vw, 4.5rem); font-weight:800; color:#fff; line-height:1; margin-bottom:2rem; text-transform:capitalize;"
        >
          {client.services[0]}
          <br />
          <span style="opacity:0.9; font-weight:400;">{client.services[1]}</span
          >
          <br />
          {client.services[2]}
        </h1>
        <p
          style="font-size:1.15rem; color:rgba(255,255,255,0.8); line-height:1.7; margin-bottom:2.5rem; max-width:500px;"
        >
          {client.tagline}. We provide professional landscaping solutions
          tailored to your needs in {client.city} and surrounding areas.
        </p>
        <div style="display:flex; gap:1.25rem; flex-wrap:wrap">
          <a
            href="/services"
            class="btn-primary"
            style="background:#84cc16; color:#fff;">Explore Garden</a
          >
          <a href="/about" class="btn-outline">Learn More</a>
        </div>
      </div>

      <div style="position:relative;">
        <!-- Wave Pattern -->
        <div
          class="decorative-waves"
          style="position:absolute; top:-40px; right:-40px; z-index:0; opacity:0.3;"
        >
          <svg width="200" height="200" viewBox="0 0 200 200">
            <circle
              cx="100"
              cy="100"
              r="40"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="55"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="70"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
            <circle
              cx="100"
              cy="100"
              r="85"
              fill="none"
              stroke="#fff"
              stroke-width="1"></circle>
          </svg>
        </div>

        <div
          class="hero-image-wrapper"
          style="position:relative; z-index:5; border-radius: 40px 40px 200px 40px; overflow:hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5);"
        >
          <img
            src="/images/hero-gardener.png"
            alt="Gardening Professional"
            style="width:100%; height:600px; object-fit:cover;"
          />
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes float {
      0%,
      100% {
        transform: translate3d(0, 0, 0);
      }
      50% {
        transform: translate3d(0, -20px, 0);
      }
    }

    @keyframes float-slow {
      0%,
      100% {
        transform: translate3d(0, 0, 0) rotate(0deg);
      }
      50% {
        transform: translate3d(0, -15px, 0) rotate(2deg);
      }
    }

    @keyframes rotate-pulse {
      0% {
        transform: rotate(0deg) scale(1);
        opacity: 0.3;
      }
      50% {
        transform: rotate(180deg) scale(1.05);
        opacity: 0.5;
      }
      100% {
        transform: rotate(360deg) scale(1);
        opacity: 0.3;
      }
    }

    .hero-image-wrapper {
      animation: float 6s ease-in-out infinite;
      will-change: transform;
    }

    .decorative-leaf {
      animation: float-slow 8s ease-in-out infinite;
      will-change: transform;
    }

    .decorative-waves {
      animation: rotate-pulse 12s linear infinite;
      will-change: transform, opacity;
    }

    @media (max-width: 968px) {
      .container {
        grid-template-columns: 1fr !important;
        gap: 3rem !important;
        padding-top: 4rem !important;
      }
      .hero-image-wrapper {
        order: -1;
        animation-duration: 4s;
      }
      h1 {
        font-size: 3rem !important;
      }
    }
  </style>

  <div class="marquee-wrapper">
    <div class="marquee-strip primary-strip">
      <div class="marquee-content">
        {
          [...Array(4)].map(() => (
            <>
              {[
                "✓ Licensed & Insured",
                "✓ Free Estimates",
                "✓ Same Day Service",
                "✓ 5-Star Rated",
                "✓ Satisfaction Guaranteed",
              ].map((b) => (
                <span class="marquee-item">{b}</span>
              ))}
            </>
          ))
        }
      </div>
    </div>
    <div class="marquee-strip light-strip">
      <div class="marquee-content reverse">
        {
          [...Array(4)].map(() => (
            <>
              {[
                "✓ Licensed & Insured",
                "✓ Free Estimates",
                "✓ Same Day Service",
                "✓ 5-Star Rated",
                "✓ Satisfaction Guaranteed",
              ].map((b) => (
                <span class="marquee-item">{b}</span>
              ))}
            </>
          ))
        }
      </div>
    </div>
  </div>

  <style>
    .marquee-wrapper {
      position: relative;
      background: #fff;
      padding: 4rem 0;
      overflow: hidden;
      margin-top: -3rem;
      z-index: 20;
    }

    .marquee-strip {
      display: flex;
      white-space: nowrap;
      padding: 1rem 0;
      width: 120%;
      margin-left: -10%;
    }

    .primary-strip {
      background: var(--primary);
      color: #fff;
      transform: rotate(-2deg);
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
      z-index: 2;
    }

    .light-strip {
      background: #f8fafc;
      color: #334155;
      transform: rotate(1deg);
      margin-top: -3.5rem;
      border-top: 1px solid #e2e8f0;
      border-bottom: 1px solid #e2e8f0;
      z-index: 1;
    }

    .marquee-content {
      display: flex;
      gap: 3rem;
      animation: marquee 30s linear infinite;
    }

    .marquee-content.reverse {
      animation: marquee-reverse 35s linear infinite;
    }

    .marquee-item {
      font-family: "Outfit", sans-serif;
      font-weight: 800;
      font-size: 1.25rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 3rem;
    }

    .marquee-item::after {
      content: "|";
      opacity: 0.3;
    }

    @keyframes marquee {
      0% {
        transform: translateX(0);
      }
      100% {
        transform: translateX(-50%);
      }
    }

    @keyframes marquee-reverse {
      0% {
        transform: translateX(-50%);
      }
      100% {
        transform: translateX(0);
      }
    }
  </style>

  <section
    style="padding: 8rem 1.5rem; background: #f0fdf4; position: relative; overflow: hidden;"
  >
    <!-- Grass/Leaf Patterns -->
    <div
      style="position: absolute; top: 0; left: 0; width: 100%; height: 80px; opacity: 0.08; pointer-events: none; background-image: url(&quot;data:image/svg+xml,%3Csvg width='120' height='60' viewBox='0 0 120 60' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 60C10 40 5 10 20 10C35 10 30 40 40 60C50 40 45 10 60 10C75 10 70 40 80 60C90 40 85 10 100 10C115 10 110 40 120 60' stroke='%232d5a3d' stroke-width='2'/%3E%3C/svg%3E&quot;); background-repeat: repeat-x;"
    >
    </div>
    <div
      style="position: absolute; bottom: 0; left: 0; width: 100%; height: 80px; opacity: 0.08; pointer-events: none; background-image: url(&quot;data:image/svg+xml,%3Csvg width='120' height='60' viewBox='0 0 120 60' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 60C10 40 5 10 20 10C35 10 30 40 40 60C50 40 45 10 60 10C75 10 70 40 80 60C90 40 85 10 100 10C115 10 110 40 120 60' stroke='%232d5a3d' stroke-width='2'/%3E%3C/svg%3E&quot;); background-repeat: repeat-x; transform: rotate(180deg);"
    >
    </div>

    <div class="container" style="position: relative; z-index: 1;">
      <!-- Header Section -->
      <div
        class="services-header"
        style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 4rem; align-items: flex-end; margin-bottom: 5rem;"
      >
        <div>
          <div
            style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.5rem;"
          >
            <div
              style={`width: 32px; height: 32px; border-radius: 8px; background: ${primary}15; display: flex; align-items: center; justify-content: center;`}
            >
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke={primary}
                stroke-width="2"
                ><path
                  d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 3.28 2 8 0 3.87-3.13 7-7 7h-3"
                ></path></svg
              >
            </div>
            <span
              style={`color: ${primary}; font-weight: 700; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 1px;`}
              >Services</span
            >
          </div>
          <h2
            style={`font-size: clamp(2.5rem, 5vw, 3.5rem); line-height: 1.1; color: ${primary}; font-weight: 800;`}
          >
            Comprehensive {client.industry} services for homeowners and businesses
            in
            {client.city}.
          </h2>
        </div>
        <div>
          <p
            style="font-size: 1.15rem; color: #4b5563; line-height: 1.7; margin-bottom: 2rem;"
          >
            Enhance your outdoor space with our professional garden landscaping
            services, customized to suit every need and preference. From design
            to installation, we create beautiful, functional gardens that
            reflect your style.
          </p>
          <div style="display: flex; gap: 0.5rem;">
            <div
              style={`width: 10px; height: 10px; border-radius: 50%; background: ${primary};`}
            >
            </div>
            <div
              style="width: 10px; height: 10px; border-radius: 50%; background: #d1d5db;"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Services Grid -->
      <div
        class="services-grid"
        style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2.5rem;"
      >
        {
          displayServices.map((s: any, i: number) => (
            <a
              href={`/services/${s.title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "")}`}
              class="service-card"
              style="position: relative; height: 480px; border-radius: 40px; overflow: hidden; cursor: pointer; display: block; text-decoration: none;"
            >
              <img
                src={s.image?.url || s.image || `/images/service-${(i % 3) + 1}.png`}
                alt={s.title}
                style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.8s ease;"
              />
              <div class="service-overlay" />
              <div class="service-content">
                <h3 class="service-title">{s.title}</h3>
                <p class="service-description">{s.description}</p>
                <div class="service-dot" />
                <div class="service-arrow">
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <style>
    .service-card {
      transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.6s cubic-bezier(0.4, 0, 0.2, 1);
      will-change: transform, opacity;
    }

    .service-card:hover {
      transform: translateY(-10px);
      box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.25);
    }

    .service-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(
        to bottom,
        rgba(6, 78, 59, 0.4) 0%,
        rgba(6, 78, 59, 0.7) 100%
      );
      opacity: 0.6;
      transition: all 0.5s ease;
    }

    .service-card:hover .service-overlay {
      opacity: 0.9;
      background: rgba(6, 78, 59, 0.85);
    }

    .service-card:hover img {
      transform: scale(1.1);
    }

    .service-content {
      position: absolute;
      inset: 0;
      padding: 3rem;
      display: flex;
      flex-direction: column;
      color: #fff;
      z-index: 2;
    }

    .service-title {
      font-size: 2rem;
      font-weight: 700;
      margin-bottom: 1.5rem;
      transition: transform 0.5s ease;
    }

    .service-description {
      font-size: 1.2rem;
      line-height: 1.6;
      opacity: 0;
      transform: translateY(20px);
      transition: all 0.5s ease 0.1s;
      max-width: 90%;
    }

    .service-card:hover .service-description {
      opacity: 1;
      transform: translateY(0);
    }

    .service-dot {
      width: 12px;
      height: 12px;
      background: #22c55e;
      border-radius: 50%;
      margin: 2rem 0;
      opacity: 0;
      transform: scale(0);
      transition: all 0.4s ease 0.2s;
    }

    .service-card:hover .service-dot {
      opacity: 1;
      transform: scale(1);
    }

    .service-arrow {
      margin-top: auto;
      width: 64px;
      height: 64px;
      background: #fff;
      color: #064e3b;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      transform: translateX(-100px);
      opacity: 0;
      transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) 0.3s;
    }

    .service-card:hover .service-arrow {
      transform: translateX(0);
      opacity: 1;
    }

    @media (max-width: 968px) {
      .services-grid {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
      }
      .service-card {
        height: 400px !important;
      }
      .service-description {
        opacity: 1;
        transform: none;
      }
      .service-arrow {
        transform: none;
        opacity: 1;
      }
      .services-header {
        grid-template-columns: 1fr !important;
        gap: 2rem !important;
        text-align: center;
        align-items: center !important;
      }
      .services-header > div:first-child > div {
        justify-content: center;
      }
      .services-header > div:last-child {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
    }

    @media (max-width: 1024px) {
      .why-choose-us .container {
        grid-template-columns: 1fr !important;
        gap: 3rem !important;
        text-align: center;
      }
      .why-choose-us .content-column {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .why-choose-us .features-grid {
        justify-content: center;
      }
      .why-choose-us .visual-column {
        order: 2;
      }
    }
  </style>

  <section
    class="why-choose-us"
    style="padding: 120px 1.5rem; overflow: hidden; background: #fff; position: relative;"
  >
    <div
      class="container"
      style="max-width: 1400px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 6rem; align-items: center;"
    >
      <!-- Left: Visual Column -->
      <div
        class="visual-column"
        style="position: relative; display: flex; justify-content: center; align-items: center;"
      >
        <!-- Background Shape -->
        <div
          style={`position: absolute; width: 140%; height: 80%; background: ${primary}12; border-radius: 500px; transform: rotate(-10deg); left: -20%; z-index: 1;`}
        >
        </div>
        <!-- Decorative Dots -->
        <div
          style={`position: absolute; top: 15%; right: 10%; width: 15px; height: 15px; background: ${primary}; border-radius: 50%; z-index: 2;`}
        >
        </div>
        <div
          style={`position: absolute; bottom: 20%; left: -5%; width: 10px; height: 10px; background: ${primary}44; border-radius: 50%; z-index: 2;`}
        >
        </div>
        <!-- Image -->
        <img
          src="/expert.png"
          alt="Our Expert"
          style="position: relative; z-index: 3; width: 100%; max-width: 550px; filter: drop-shadow(0 30px 60px rgba(0,0,0,0.12));"
        />
      </div>

      <!-- Right: Content Column -->
      <div class="content-column">
        <div
          style="display: flex; align-items: center; gap: 0.85rem; margin-bottom: 2rem;"
        >
          <div
            style={`width: 40px; height: 40px; background: ${primary}15; border-radius: 12px; display: flex; align-items: center; justify-content: center; color: ${primary};`}
          >
            <svg width="22" height="22" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C11,20 12,17 12,17C12,17 13,20 16,20C18.95,20 20.9,17.75 21,15C21.05,12.1 20.21,10.04 18.4,8.5C18,8.2 17.5,8 17,8M8,18C7.5,18 7,17.5 7,17C7,16.5 7.5,16 8,16C8.5,16 9,16.5 9,17C9,17.5 8.5,18 8,18M11,14C10.5,14 10,13.5 10,13C10,12.5 10.5,12 11,12C11.5,12 12,12.5 12,13C12,13.5 11.5,14 11,14M16,18C15.5,18 15,17.5 15,17C15,16.5 15.5,16 16,16C16.5,16 17,16.5 17,17C17,17.5 16.5,18 16,18Z"
              ></path>
            </svg>
          </div>
          <span
            style={`font-weight: 800; color: ${primary}; font-size: 0.95rem; text-transform: uppercase; letter-spacing: 2px;`}
            >Why Choose Us</span
          >
        </div>

        <h2
          style={`font-size: clamp(2.5rem, 5vw, 4rem); line-height: 1.05; font-weight: 800; color: #111; margin-bottom: 2rem; letter-spacing: -1px;`}
        >
          Why choose us <span style={`color: ${primary};`}>for your</span> landscaping
          needs?
        </h2>

        <p
          style="font-size: 1.15rem; line-height: 1.8; color: #555; margin-bottom: 3.5rem; max-width: 600px;"
        >
          Choose us for expert landscaping: personalized designs, quality
          craftsmanship, and dedicated service to make your outdoor space
          exceptional.
        </p>

        <div
          class="features-grid"
          style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 2.5rem;"
        >
          {
            [
              {
                title: "Years of Experience",
                desc: "Trusted by hundreds of local homeowners with years of expertise.",
                icon: (
                  <svg
                    width="28"
                    height="28"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M5 3v4M19 3v4M5 11h14M5 15h14M5 19h14M12 3v18"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                ),
              },
              {
                title: "Fast Response",
                desc: "Same-day service. We show up when we say, every time.",
                icon: (
                  <svg
                    width="28"
                    height="28"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M13 10V3L4 14h7v7l9-11h-7z"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                ),
              },
              {
                title: "Quality Guaranteed",
                desc: "100% satisfaction guarantee on every landscaping project.",
                icon: (
                  <svg
                    width="28"
                    height="28"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                ),
              },
              {
                title: "Fair Pricing",
                desc: "Transparent quotes with no hidden fees or surprises.",
                icon: (
                  <svg
                    width="28"
                    height="28"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    viewBox="0 0 24 24"
                  >
                    <path
                      d="M12 8c-1.657 0-3 1.343-3 3s1.343 3 3 3 3 1.343 3 3-1.343 3-3 3m0-12c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    />
                  </svg>
                ),
              },
            ].map((feature) => (
              <div class="feature-item">
                <div
                  style={`width: 60px; height: 60px; background: ${primary}12; border-radius: 18px; display: flex; align-items: center; justify-content: center; color: ${primary}; margin-bottom: 1.25rem;`}
